generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id            Int      @id @default(autoincrement())
  slug          String   @unique
  title         String
  description   String
  lat           Float
  lng           Float
  videoUrl      String?
  images        String[]
  status        String
  priceRange    String?
  bedrooms      String?
  area          String?
  featured      Boolean  @default(false)
  featuredOrder Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteSetting {
  key   String @id
  value String
}

model Lead {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String
  telefono  String
  mensaje   String?
  createdAt DateTime @default(now())
}

model AboutSection {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  image       String
  order       Int
}
